        "def media(A,B,C):\n",
        "  PA = 2\n",
        "  PB = 3\n",
        "  PC = 5\n",
        "  media = ((PA*A + PB*B + PC*C)/(PA + PB + PC))\n",
        "  print(f\"A Media é {media}\")\n",
        "\n",
        "def desvio_P(valores):\n",
        "    return variancia(valores) ** 0.5\n",
        "\n",
        "def variancia(valores):\n",
        "  media = sum(valores) / len(valores)\n",
        "  variancia = sum((x - media) ** 2 for x in valores)\n",
        "  return variancia"
      ]
